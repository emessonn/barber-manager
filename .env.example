# ─── Database (Vercel Postgres) ───────────────────────────────────────────────
POSTGRES_PRISMA_URL=postgresql://user:password@host/database
POSTGRES_URL_NON_POOLING=postgresql://user:password@host/database

# ─── Authentication (Auth.js v5) ──────────────────────────────────────────────
AUTH_URL=http://localhost:3000
AUTH_SECRET=your-secret-here-change-in-production
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here-change-in-production

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── App URL (usada em back_urls do MercadoPago e links do WhatsApp) ──────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Em produção: NEXT_PUBLIC_APP_URL=https://seudominio.com

# ─── WhatsApp (Evolution API) ─────────────────────────────────────────────────
# Docs: https://doc.evolution-api.com
EVOLUTION_API_URL=https://sua-evolution-api.up.railway.app
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_INSTANCE=barber-manager

# ─── Email (Resend) — fallback quando WhatsApp não está configurado ────────────
# Docs: https://resend.com/docs
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=noreply@seu-dominio.com

# ─── SMS (Twilio) — fallback quando WhatsApp e Email não estão configurados ───
# Docs: https://www.twilio.com/docs/sms
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+15017122661

# ─── MercadoPago ──────────────────────────────────────────────────────────────
# Docs: https://www.mercadopago.com.br/developers
# Use TEST-... para sandbox, sem prefixo para produção
MERCADOPAGO_ACCESS_TOKEN=TEST-your-access-token-here
MERCADOPAGO_WEBHOOK_SECRET=your-webhook-secret

# ─── Cron Jobs (Vercel) ───────────────────────────────────────────────────────
# Gere com: openssl rand -hex 32
CRON_SECRET=your-cron-secret-here

# ─── Node Environment ─────────────────────────────────────────────────────────
NODE_ENV=development
